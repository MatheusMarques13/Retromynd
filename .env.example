# ============================================================
# RetroMynd — environment variables
# ============================================================
# Copy this file to `.dev.vars` for local development (wrangler reads .dev.vars),
# and set the same keys as production secrets with `wrangler secret put <KEY>`.
#
# IMPORTANT: Every key that came in the original Mocha export was exposed in the
# zip and MUST be rotated/regenerated before going live.
# ------------------------------------------------------------

# --- Auth (Google OAuth + our own session) ---
# Create an OAuth 2.0 "Web application" client in Google Cloud Console.
# Authorized redirect URIs:
#   https://retromynd.com/auth/callback   (production)
#   http://localhost:5173/auth/callback   (local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# Long random string used to sign session JWTs. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=

# --- Admin ---
# Comma-separated list of emails that get admin access.
ADMIN_EMAILS=retromynd@gmail.com

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
# Webhook signing secrets — there are 3 webhook endpoints:
#   /api/webhooks/stripe, /api/webhooks/stripe-account, /api/webhooks/retropass
STRIPE_WEBHOOK_SECRET=

# --- AI / data ---
GEMINI_API_KEY=
FIRECRAWL_API_KEY=

# --- Print-on-demand (Printify) ---
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
